# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-pve-common
pkgver=1.0.0
pkgrel=1
pkgdesc="Proxmox VE common Perl library - ported for Arch Linux"
arch=('x86_64')
url="https://archmox.acreetionos.org"
license=('AGPL3')
depends=('perl' 'perl-json' 'perl-http-message' 'perl-libwww' 'perl-net-ip'
         'perl-net-dns' 'perl-io-socket-ssl' 'perl-uri' 'perl-xml-libxml'
         'perl-xml-simple' 'perl-date-format' 'perl-filesys-df'
         'perl-mailtools' 'perl-mime-lite' 'perl-template-toolkit'
         'perl-libintl-perl' 'archmox-proxmox-rs')
makedepends=('perl-module-build' 'perl-extutils-makemaker' 'make' 'gcc')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/core/pve-common"
  perl Makefile.PL INSTALLDIRS=vendor DESTDIR="${pkgdir}"
  make
}

check() {
  cd "${srcdir}/archmox-${pkgver}/packages/core/pve-common"
  make test
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/core/pve-common"
  make install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
