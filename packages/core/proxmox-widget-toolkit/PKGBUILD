# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-proxmox-widget-toolkit
pkgver=1.0.0
pkgrel=1
pkgdesc="Proxmox widget toolkit (ExtJS-based UI components) - ported for Arch Linux"
arch=('x86_64')
url="https://archmox.acreetionos.org"
license=('AGPL3' 'LGPL2.1')
depends=('proxmox-archive-keyring' 'sencha-framework')
makedepends=('nodejs' 'npm' 'sass' 'sencha-cmd')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/core/proxmox-widget-toolkit"
  make
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/core/proxmox-widget-toolkit"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
