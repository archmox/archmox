# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-proxmox-i18n
pkgver=1.0.0
pkgrel=1
pkgdesc="Proxmox internationalization (i18n) files - ported for Arch Linux"
arch=('x86_64')
url="https://archmox.acreetionos.org"
license=('AGPL3')
depends=('glibc')
makedepends=('gettext' 'make')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/core/proxmox-i18n"
  make
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/core/proxmox-i18n"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
