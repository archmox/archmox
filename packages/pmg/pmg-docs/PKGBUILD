# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-pmg-docs
pkgver=1.0.0
pkgrel=1
pkgdesc="Proxmox Mail Gateway documentation - ported for Arch Linux"
arch=('any')
url="https://archmox.acreetionos.org"
license=('AGPL3')
depends=()
makedepends=('asciidoc' 'xmlto' 'docbook-xsl' 'libxml2' 'libxslt'
             'dblatex' 'w3m' 'make')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/pmg/pmg-docs"
  make
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/pmg/pmg-docs"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
