# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-pve-xtermjs
pkgver=1.0.0
pkgrel=1
pkgdesc="Proxmox VE xterm.js terminal integration - ported for Arch Linux"
arch=('any')
url="https://archmox.acreetionos.org"
license=('AGPL3' 'MIT')
depends=('nodejs' 'xterm')
makedepends=('npm' 'make')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/pve/pve-xtermjs"
  make
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/pve/pve-xtermjs"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
