# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-pve-ha-manager
pkgver=1.0.0
pkgrel=1
pkgdesc="Proxmox VE High Availability manager - ported for Arch Linux"
arch=('x86_64')
url="https://archmox.acreetionos.org"
license=('AGPL3')
depends=('archmox-pve-common' 'archmox-pve-cluster' 'archmox-pve-access-control'
         'archmox-pve-guest-common'
         'perl' 'perl-json' 'perl-libwww' 'perl-io-socket-ssl'
         'perl-net-ip' 'perl-xml-libxml' 'perl-filesys-df'
         'perl-string-shellquote' 'perl-linux-inotify2'
         'corosync' 'libqb' 'watchdog')
makedepends=('make' 'gcc' 'perl-module-build')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/pve/pve-ha-manager"
  make
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/pve/pve-ha-manager"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
