# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-pve-http-server
pkgver=1.0.0
pkgrel=1
pkgdesc="Proxmox VE HTTP server - ported for Arch Linux"
arch=('x86_64')
url="https://archmox.acreetionos.org"
license=('AGPL3')
depends=('archmox-pve-common' 'archmox-pve-access-control'
         'perl' 'perl-json' 'perl-libwww' 'perl-http-daemon'
         'perl-io-socket-ssl' 'perl-net-ip' 'perl-xml-libxml'
         'perl-cgi' 'perl-crypt-openssl-rsa' 'perl-crypt-ssleay'
         'perl-uri' 'perl-template-toolkit' 'perl-file-slurp'
         'perl-authen-pam' 'perl-datetime'
         'perl-linux-inotify2' 'perl-filesys-df'
         'libjs-extjs' 'proxmox-archive-keyring')
makedepends=('make' 'gcc' 'perl-module-build')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/pve/pve-http-server"
  make
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/pve/pve-http-server"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
