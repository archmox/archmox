# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-proxmox-datacenter-manager
pkgver=1.0.0
pkgrel=1
pkgdesc="Proxmox Datacenter Manager - ported for Arch Linux"
arch=('x86_64')
url="https://archmox.acreetionos.org"
license=('AGPL3')
depends=('archmox-pve-common' 'archmox-pve-cluster' 'archmox-pve-http-server'
         'archmox-pve-access-control' 'archmox-proxmox-rs'
         'archmox-proxmox-yew-comp'
         'perl' 'perl-json' 'perl-libwww' 'perl-io-socket-ssl'
         'perl-net-ip' 'perl-xml-libxml' 'perl-template-toolkit'
         'perl-crypt-openssl-rsa' 'perl-crypt-ssleay'
         'perl-datetime' 'perl-linux-inotify2' 'perl-filesys-df')
makedepends=('make' 'gcc' 'perl-module-build' 'rust' 'cargo')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/pve/proxmox-datacenter-manager"
  make
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/pve/proxmox-datacenter-manager"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
