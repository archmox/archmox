# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-pve-cluster
pkgver=1.0.0
pkgrel=1
pkgdesc="Proxmox VE cluster management - ported for Arch Linux"
arch=('x86_64')
url="https://archmox.acreetionos.org"
license=('AGPL3')
depends=('archmox-pve-common' 'archmox-pve-access-control'
         'corosync' 'libqb' 'perl' 'perl-json' 'perl-libwww'
         'perl-io-socket-ssl' 'perl-net-ip' 'perl-xml-libxml'
         'perl-crypt-openssl-rsa' 'perl-crypt-ssleay'
         'perl-linux-inotify2' 'perl-filesys-df' 'perl-date-format'
         'perl-net-ssleay' 'libpve-network-perl')
makedepends=('make' 'gcc' 'perl-module-build' 'cmocka')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/pve/pve-cluster"
  make
}

check() {
  cd "${srcdir}/archmox-${pkgver}/packages/pve/pve-cluster"
  make test
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/pve/pve-cluster"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
