# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-redhat-cluster-pve
pkgver=1.0.0
pkgrel=1
pkgdesc="Red Hat cluster suite with Proxmox patches - ported for Arch Linux"
arch=('x86_64')
url="https://archmox.acreetionos.org"
license=('GPL2' 'LGPL2.1')
depends=('glibc' 'libxml2' 'libqb' 'corosync' 'pacemaker' 'nss')
makedepends=('make' 'gcc' 'pkg-config' 'autoconf' 'automake' 'libtool')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/infra/redhat-cluster-pve"
  ./autogen.sh
  ./configure --prefix=/usr --sysconfdir=/etc --localstatedir=/var
  make
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/infra/redhat-cluster-pve"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
