# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-fence-agents-pve
pkgver=1.0.0
pkgrel=1
pkgdesc="Fence agents for Proxmox VE - ported for Arch Linux"
arch=('any')
url="https://archmox.acreetionos.org"
license=('GPL2')
depends=('perl' 'perl-libwww' 'perl-json' 'perl-io-socket-ssl'
         'perl-net-ip' 'perl-xml-libxml' 'perl-crypt-openssl-rsa'
         'perl-crypt-ssleay' 'fence-agents')
makedepends=('make')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/infra/fence-agents-pve"
  make
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/infra/fence-agents-pve"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
