# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-vncterm
pkgver=1.0.0
pkgrel=1
pkgdesc="VNC terminal for Proxmox - ported for Arch Linux"
arch=('x86_64')
url="https://archmox.acreetionos.org"
license=('AGPL3')
depends=('glibc' 'libvncserver' 'libssl' 'libcrypto' 'zlib' 'lzo')
makedepends=('make' 'gcc' 'pkg-config' 'cmake')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/infra/vncterm"
  make
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/infra/vncterm"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
