# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-spiceterm
pkgver=1.0.0
pkgrel=1
pkgdesc="SPICE terminal for Proxmox - ported for Arch Linux"
arch=('x86_64')
url="https://archmox.acreetionos.org"
license=('AGPL3')
depends=('glibc' 'spice-server' 'spice-protocol' 'libssl' 'zlib')
makedepends=('make' 'gcc' 'pkg-config')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/infra/spiceterm"
  make
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/infra/spiceterm"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
