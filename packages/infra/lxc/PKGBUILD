# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-lxc
pkgver=1.0.0
pkgrel=1
pkgdesc="LXC containers with Proxmox patches - ported for Arch Linux"
arch=('x86_64')
url="https://archmox.acreetionos.org"
license=('LGPL2.1')
depends=('glibc' 'libcap' 'libseccomp' 'libselinux' 'gnutls'
         'libapparmor' 'rsync' 'pigz')
makedepends=('make' 'gcc' 'pkg-config' 'meson' 'ninja' 'python')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/infra/lxc"
  mkdir -p build && cd build
  meson setup --prefix=/usr --sysconfdir=/etc --localstatedir=/var \
    -Dtests=false -Dmanpages=false ..
  ninja
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/infra/lxc/build"
  DESTDIR="${pkgdir}" ninja install
  install -Dm644 ../LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
