# Maintainer: Archmox Team <dev@archmox.acreetionos.org>

pkgname=archmox-ksm-control-daemon
pkgver=1.0.0
pkgrel=1
pkgdesc="KSM control daemon for Proxmox - ported for Arch Linux"
arch=('x86_64')
url="https://archmox.acreetionos.org"
license=('AGPL3')
depends=('glibc')
makedepends=('make' 'gcc')
source=("https://github.com/archmox/archmox/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/archmox-${pkgver}/packages/infra/ksm-control-daemon"
  make
}

package() {
  cd "${srcdir}/archmox-${pkgver}/packages/infra/ksm-control-daemon"
  make DESTDIR="${pkgdir}" install
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
